# Which model backend the app uses.
#   ollama  -> local dev (Ollama running on your machine)
#   hf      -> Hugging Face Spaces deploy (transformers, CPU)
#   groq    -> frontier-tier hosted model (Llama-3.3-70B) via Groq
#   gemini  -> alternative frontier model via Google Gemini API
BACKEND=ollama

# Ollama settings (used when BACKEND=ollama)
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_HOST=http://localhost:11434

# HF settings (used when BACKEND=hf)
HF_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Frontier-tier model — comparison + LLM-as-judge (not needed to run the OSS chat)
# Primary: Groq. Free key from https://console.groq.com (no credit card needed)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional alternative frontier model (Gemini). Free key from https://aistudio.google.com
# (note: Gemini free tier is only ~20 requests/day, too small for the full eval)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Short-term memory: approximate token budget for recent history sent each turn
MEMORY_MAX_TOKENS=2048
# Optional hard cap on number of messages kept (0 = no cap, use token budget only)
MEMORY_MAX_TURNS=0
